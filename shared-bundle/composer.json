{
    "name": "app/shared-bundle",
    "description": "Shared contracts and abstractions for the Symfony microservices task.",
    "type": "symfony-bundle",
    "license": "proprietary",
    "require": {
        "php": ">=8.1",
        "doctrine/orm": "^2.20 || ^3.0",
        "symfony/framework-bundle": "^6.4 || ^7.0"
    },
    "autoload": {
        "psr-4": {
            "App\\SharedBundle\\": "src/"
        }
    },
    "extra": {
        "symfony": {
            "bundle": "App\\SharedBundle\\SharedBundle"
        }
    }
}
